# dependency directories (المكتبات التي يتم تحميلها تلقائياً)
node_modules/
/jspm_packages/

# build / production (المجلدات التي تنتج عند عمل النسخة النهائية للموقع)
/build
/dist
/out

# Debug logs (ملفات تسجيل الأخطاء المؤقتة)
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Operating System Files (ملفات النظام المؤقتة الخاصة بجهازك)
.DS_Store
Thumbs.db

# Environmental variables (الملفات التي تحتوي على كلمات المرور والمفاتيح السرية)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local