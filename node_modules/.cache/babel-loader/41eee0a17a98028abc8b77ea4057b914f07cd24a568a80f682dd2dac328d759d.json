":3,"names":["Aos","React","useEffect","jsxDEV","_jsxDEV","AboutUs","_s","init","duration","window","scrollTo","className","dir","children","fileName","_jsxFileName","lineNumber","columnNumber","class","_c","$RefreshReg$"],"sources":["D:/Courses/static website/biscoza/src/Pages/AboutUs/AboutUs.jsx"],"sourcesContent":["import \"./AboutUs.css\";\r\nimport Aos from \"aos\";\r\nimport \"aos/dist/aos.css\";\r\nimport React, { useEffect } from \"react\";\r\n\r\nfunction AboutUs() {\r\n  useEffect(() => {\r\n    Aos.init({ duration: 2000 });\r\n    window.scrollTo(0, 0);\r\n  }, []);\r\n  return (\r\n    <section className=\"about-us\" data-aos=\"fade-up\" data-aos-duration=\"1500\" dir=\"rtl\">\r\n      <h1 data-aos=\"fade-up\" data-aos-duration=\"1500\">\r\n        من نحن\r\n      </h1>\r\n      <hr class=\"solid\" data-aos=\"fade-up\" data-aos-duration=\"1500\"></hr>\r\n\r\n      <h2 data-aos=\"fade-up\" data-aos-duration=\"1500\">\r\n        حكاية تأسيس بيسكوزا\r\n      </h2>\r\n      <p data-aos=\"fade-up\" data-aos-duration=\"1500\">\r\n      شركة سورية متخصصة في صناعة البسكويت تأسست عام 2023 بشغف كبير لتقديم منتجات عالية الجودة تجمع بين المكونات المتميزة والأصناف اللذيذة لتوفر تجربة طعم استثنائية لكل من يتذوقها.      </p>\r\n      <p data-aos=\"fade-up\" data-aos-duration=\"1500\">\r\n      نحن في شركة بيسكوزا منذ أن بدأنا نحرص على استخدام أجود المكونات لإنتاج أصناف ذات جودة عالية من البسكويت المحشي والمغطس بالشوكولا والمارشميلو اللذيذ مع إدخال وصفاتنا الشهيّة والمتميزة لتضفي لحظات من السعادة على حياتكم اليومية.       </p>\r\n      <p data-aos=\"fade-up\" data-aos-duration=\"1500\">\r\n      التزامنا بالجودة والتميز والمعايير العالمية لتحقيق رضا زبائننا هو ما يدفعنا للحفاظ على أعلى المعايير في كل منتج نقدمه من حيث جودة المكونات، النظافة والتعقيم، المختبرات وخطوط الإنتاج مُدارة بالكامل من قبل أجهزة الكومبيوتر والتحكم الآلي دون تدخل العامل البشري خلال مراحل الإنتاج، حتى اختيار الأغلفة ومواد التغليف الراقية والتي تليق بمنتجات بيسكوزا لنضيف بصمة متميزة في عالم البسكويت والشوكولا.      </p>\r\n      <p data-aos=\"fade-up\" data-aos-duration=\"1500\">\r\n      في بيسكوزا نؤمن أن قطعة من البسكويت قد تكون سبباً لسعادة تشعر بها خلال يومك      </p>\r\n      {/*\r\n      <p data-aos=\"fade-up\" data-aos-duration=\"1500\">\r\n        Whether you're savoring a moment alone or celebrating with loved ones, biscoza is here to make it special. Join us on this flavorful journey, and discover why biscoza is the name people trust for irresistible biscuits and chocolates.\r\n      </p>\r\n      <p data-aos=\"fade-up\" data-aos-duration=\"1500\">\r\n        Because life is sweeter with biscoza.\r\n      </p>\r\n      <h2 data-aos=\"fade-up\" data-aos-duration=\"1500\">\r\n        Meet Our Team\r\n      </h2>\r\n      <h3 data-aos=\"fade-up\" data-aos-duration=\"1500\">\r\n        Emily Johnson - Founder & Chief Chocolatier\r\n      </h3>\r\n      <p data-aos=\"fade-up\" data-aos-duration=\"1500\">\r\n        Emily’s passion for sweets led her to create unique flavor combinations\r\n        that dance on your taste buds. With a background in culinary arts, she\r\n        ensures every bite is a moment of bliss.\r\n      </p>\r\n      <h3 data-aos=\"fade-up\" data-aos-duration=\"1500\">\r\n        Alex Rodriguez - Head Baker\r\n      </h3>\r\n      <p data-aos=\"fade-up\" data-aos-duration=\"1500\">\r\n        Alex’s love for biscuits started at an early age. His dedication to\r\n        perfection ensures that each biscuit is flaky, buttery, and\r\n        irresistible.\r\n      </p>\r\n      <h2 data-aos=\"fade-up\" data-aos-duration=\"1500\">\r\n        Our Evolution\r\n      </h2>\r\n      <p data-aos=\"fade-up\" data-aos-duration=\"1500\">\r\n        From humble beginnings at local farmers’ markets to our bustling\r\n        storefront, we’ve grown alongside our loyal customers. We’ve expanded\r\n        our product line, introduced vegan options, and even won awards for our\r\n        dark chocolate truffles. Join us on this sweet adventure, and let our\r\n        treats brighten your day!\r\n      </p>\r\n      */}\r\n    </section>\r\n  );\r\n}\r\n\r\nexport default AboutUs;\r\n"],"mappings":";;AAAA,OAAO,eAAe;AACtB,OAAOA,GAAG,MAAM,KAAK;AACrB,OAAO,kBAAkB;AACzB,OAAOC,KAAK,IAAIC,SAAS,QAAQ,OAAO;AAAC,SAAAC,MAAA,IAAAC,OAAA;AAEzC,SAASC,OAAOA,CAAA,EAAG;EAAAC,EAAA;EACjBJ,SAAS,CAAC,MAAM;IACdF,GAAG,CAACO,IAAI,CAAC;MAAEC,QAAQ,EAAE;IAAK,CAAC,CAAC;IAC5BC,MAAM,CAACC,QAAQ,CAAC,CAAC,EAAE,CAAC,CAAC;EACvB,CAAC,EAAE,EAAE,CAAC;EACN,oBACEN,OAAA;IAASO,SAAS,EAAC,UAAU;IAAC,YAAS,SAAS;IAAC,qBAAkB,MAAM;IAACC,GAAG,EAAC,KAAK;IAAAC,QAAA,gBACjFT,OAAA;MAAI,YAAS,SAAS;MAAC,qBAAkB,MAAM;MAAAS,QAAA,EAAC;IAEhD;MAAAC,QAAA,EAAAC,YAAA;MAAAC,UAAA;MAAAC,YAAA;IAAA,OAAI,CAAC,eACLb,OAAA;MAAIc,KAAK,EAAC,OAAO;MAAC,YAAS,SAAS;MAAC,qBAAkB;IAAM;MAAAJ,QAAA,EAAAC,YAAA;MAAAC,UAAA;MAAAC,YAAA;IAAA,OAAK,CAAC,eAEnEb,OAAA;MAAI,YAAS,SAAS;MAAC,qBAAkB,MAAM;MAAAS,QAAA,EAAC;IAEhD;MAAAC,QAAA,EAAAC,YAAA;MAAAC,UAAA;MAAAC,YAAA;IAAA,OAAI,CAAC,eACLb,OAAA;MAAG,YAAS,SAAS;MAAC,qBAAkB,MAAM;MAAAS,QAAA,EAAC;IACoI;MAAAC,QAAA,EAAAC,YAAA;MAAAC,UAAA;MAAAC,YAAA;IAAA,OAAG,CAAC,eACvLb,OAAA;MAAG,YAAS,SAAS;MAAC,qBAAkB,MAAM;MAAAS,QAAA,EAAC;IACyL;MAAAC,QAAA,EAAAC,YAAA;MAAAC,UAAA;MAAAC,YAAA;IAAA,OAAG,CAAC,eAC5Ob,OAAA;MAAG,YAAS,SAAS;MAAC,qBAAkB,MAAM;MAAAS,QAAA,EAAC;IAC8V;MAAAC,QAAA,EAAAC,YAAA;MAAAC,UAAA;MAAAC,YAAA;IAAA,OAAG,CAAC,eACjZb,OAAA;MAAG,YAAS,SAAS;MAAC,qBAAkB,MAAM;MAAAS,QAAA,EAAC;IACkC;MAAAC,QAAA,EAAAC,YAAA;MAAAC,UAAA;MAAAC,YAAA;IAAA,OAAG,CAAC;EAAA;IAAAH,QAAA,EAAAC,YAAA;IAAAC,UAAA;IAAAC,YAAA;EAAA,OAsC9E,CAAC;AAEd;AAACX,EAAA,CA9DQD,OAAO;AAAAc,EAAA,GAAPd,OAAO;AAgEhB,eAAeA,OAAO;AAAC,IAAAc,EAAA;AAAAC,YAAA,CAAAD,EAAA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}