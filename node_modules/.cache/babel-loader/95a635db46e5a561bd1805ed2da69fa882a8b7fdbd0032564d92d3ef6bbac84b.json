>\r\n      <p data-aos=\"fade-up\" data-aos-duration=\"1500\">\r\n      التزامنا بالجودة والتميز والمعايير العالمية لتحقيق رضا زبائننا هو ما يدفعنا للحفاظ على أعلى المعايير في كل منتج نقدمه من حيث جودة المكونات، النظافة والتعقيم، المختبرات وخطوط الإنتاج مُدارة بالكامل من قبل أجهزة الكومبيوتر والتحكم الآلي دون تدخل العامل البشري خلال مراحل الإنتاج، حتى اختيار الأغلفة ومواد التغليف الراقية والتي تليق بمنتجات بيسكوزا لنضيف بصمة متميزة في عالم البسكويت والشوكولا.      </p>\r\n      <p data-aos=\"fade-up\" data-aos-duration=\"1500\">\r\n      في بيسكوزا نؤمن أن قطعة من البسكويت قد تكون سبباً لسعادة تشعر بها خلال يومك      </p>\r\n    </section>\r\n  );\r\n}\r\n\r\nexport default AboutUs;\r\n"],"mappings":"AAAA,MAAO,eAAe,CACtB,MAAO,CAAAA,GAAG,KAAM,KAAK,CACrB,MAAO,kBAAkB,CACzB,MAAO,CAAAC,KAAK,EAAIC,SAAS,KAAQ,OAAO,CAAC,OAAAC,GAAA,IAAAC,IAAA,CAAAC,IAAA,IAAAC,KAAA,yBAEzC,QAAS,CAAAC,OAAOA,CAAA,CAAG,CACjBL,SAAS,CAAC,IAAM,CACdF,GAAG,CAACQ,IAAI,CAAC,CAAEC,QAAQ,CAAE,IAAK,CAAC,CAAC,CAC5BC,MAAM,CAACC,QAAQ,CAAC,CAAC,CAAE,CAAC,CAAC,CACvB,CAAC,CAAE,EAAE,CAAC,CACN,mBACEL,KAAA,YAASM,SAAS,CAAC,UAAU,CAAC,WAAS,SAAS,CAAC,oBAAkB,MAAM,CAACC,GAAG,CAAC,KAAK,CAAAC,QAAA,eACjFV,IAAA,OAAI,WAAS,SAAS,CAAC,oBAAkB,MAAM,CAAAU,QAAA,CAAC,iCAEhD,CAAI,CAAC,cACLV,IAAA,OAAIQ,SAAS,CAAC,OAAO,CAAC,WAAS,SAAS,CAAC,oBAAkB,MAAM,CAAK,CAAC,cAEvER,IAAA,OAAI,WAAS,SAAS,CAAC,oBAAkB,MAAM,CAAAU,QAAA,CAAC,0GAEhD,CAAI,CAAC,cACLV,IAAA,MAAG,WAAS,SAAS,CAAC,oBAAkB,MAAM,CAAAU,QAAA,CAAC,s3BACoI,CAAG,CAAC,cACvLV,IAAA,MAAG,WAAS,SAAS,CAAC,oBAAkB,MAAM,CAAAU,QAAA,CAAC,2pCACyL,CAAG,CAAC,cAC5OV,IAAA,MAAG,WAAS,SAAS,CAAC,oBAAkB,MAAM,CAAAU,QAAA,CAAC,sgEAC8V,CAAG,CAAC,cACjZV,IAAA,MAAG,WAAS,SAAS,CAAC,oBAAkB,MAAM,CAAAU,QAAA,CAAC,oYACkC,CAAG,CAAC,EAC9E,CAAC,CAEd,CAEA,cAAe,CAAAP,OAAO","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}